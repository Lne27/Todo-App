{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-desktop-tauri/dev/crates/tauri-utils/schema/capability.json",
  "identifier": "default",
  "description": "Default capability for the TODO app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "notification:allow-is-permission-granted",
    "dialog:default"
  ]
}
